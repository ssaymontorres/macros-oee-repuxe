//loop roda máquina por máquina
for n_maq = 0 to 31

	index = (n_maq * 500)//ajusta range de variável de cada máquina 

//carregamento das variáveis para as memórias da macro em caso de falta de energia
	GetData(tempo_total, "Local HMI", RW, index + 100, 1)
