	if status_maq == 0 and status_prd == 0 and inicio_parada == 0 then
		inicio_parada = 1
		SetData(inicio_parada, "Local HMI", RW, index + 286, 1)
	end if
		
	if inicio_parada == 1 then
	
//conta o tempo total da parada
	cont_seg = cont_seg + 1
	SetData(cont_seg, "Local HMI", RW, index + 203, 1)
	
	if cont_seg >= 60 then
	tempo_parada = tempo_parada + 1
	cont_seg = 0	
	SetData(cont_seg, "Local HMI", RW, index + 203, 1)
	SetData(tempo_parada, "Local HMI", RW, index + 204, 1)
	end if
	
//tempo 0 (tempo aguardando apontamento)
		if status_ultima_parada == 0 then
			tempo_aguardando_apontamento = tempo_aguardando_apontamento + 1
			
//tempo 1 (motivos definidos)	
		else if status_ultima_parada == 1 then
			tempo_motivos_1 = tempo_aguardando_apontamento + tempo_motivos_1 + 1
			tempo_aguardando_apontamento = 0
				if flag_cont_parada_1[n_maq] == false then 
					qtd_paradas_1 = qtd_paradas_1 + 1
