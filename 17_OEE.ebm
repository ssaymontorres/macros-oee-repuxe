		cont_seg = 0
		SetData(inicio_parada, "Local HMI", RW, index + 286, 1)	
		SetData(cont_seg, "Local HMI", RW, index + 203, 1)
		SetData(tempo_parada, "Local HMI", RW, index + 204, 1)	
	end if	
	
//contabiliza o acumulado produzido no turno

	if qtd_op_teorico < qtd_turno_teorico_temp then 
		qtd_turno_teorico_temp = qtd_op_teorico		
	end if 
	qtd_turno_teorico_dif = qtd_op_teorico - qtd_turno_teorico_temp
	qtd_turno_teorico = qtd_turno_teorico + qtd_turno_teorico_dif
	qtd_turno_teorico_temp = qtd_op_teorico	
	qtd_turno_teorico_dif = 0
	
	if qtd_op_pecas_boas < qtd_turno_pecas_boas_temp then 
		qtd_turno_pecas_boas_temp = qtd_op_pecas_boas
	end if	
	qtd_turno_pecas_boas_dif = qtd_op_pecas_boas - qtd_turno_pecas_boas_temp	
	qtd_turno_pecas_boas = qtd_turno_pecas_boas + qtd_turno_pecas_boas_dif	
	qtd_turno_pecas_boas_temp = qtd_op_pecas_boas
	qtd_turno_pecas_boas_dif = 0

	if qtd_op_refugo < qtd_turno_refugo_temp then 
		qtd_turno_refugo_temp = qtd_op_refugo
	end if 		
	qtd_turno_refugo_dif = qtd_op_refugo - qtd_turno_refugo_temp
	qtd_turno_refugo = qtd_turno_refugo + qtd_turno_refugo_dif	
	qtd_turno_refugo_temp = qtd_op_refugo
	qtd_turno_pecas_boas = qtd_turno_pecas_boas - qtd_turno_refugo_dif//DESCONTA O REFUGO DO ACUMULADO DE PEÇAS BOAS DO TURNO
	qtd_turno_refugo_dif = 0	
					
	if qtd_turno_pecas_boas <= 0 then //VERIFICA SE O REFUGO INSERIDO É MAIOR QUE O ACUMULADO DO TURNO, CASO POSITIVO ZERA OS REGISTRADORES
		qtd_turno_pecas_boas = 0
	end if 
	
	qtd_turno_total = qtd_turno_refugo + qtd_turno_pecas_boas

	SetData(qtd_turno_teorico, "Local HMI", RW, index + 195, 1)	
