	SetData(qtd_turno_pecas_boas_temp, "Local HMI", RW, index + 292, 1)	
	SetData(qtd_turno_pecas_boas_dif, "Local HMI", RW, index + 294, 1)			
	SetData(qtd_turno_refugo_temp, "Local HMI", RW, index + 296, 1)	
	SetData(qtd_turno_refugo_dif, "Local HMI", RW, index + 298, 1)


//atualiza variáveis após contabilizado		
	SetData(tempo_total_rodando, "Local HMI", RW, index + 102, 1)	
	SetData(tempo_aguardando_apontamento, "Local HMI", RW, index + 104, 1)
	SetData(tempo_motivos_1, "Local HMI", RW, index + 106, 1)
	SetData(tempo_motivos_2, "Local HMI", RW, index + 108, 1)
	SetData(tempo_motivos_3, "Local HMI", RW, index + 110, 1)
	SetData(tempo_motivos_4, "Local HMI", RW, index + 112, 1)
	SetData(tempo_motivos_5, "Local HMI", RW, index + 114, 1)
	SetData(tempo_motivos_6, "Local HMI", RW, index + 116, 1)
	SetData(tempo_motivos_7, "Local HMI", RW, index + 118, 1)
	SetData(tempo_motivos_8, "Local HMI", RW, index + 120, 1)
	SetData(tempo_motivos_9, "Local HMI", RW, index + 122, 1)
	SetData(tempo_motivos_10, "Local HMI", RW, index + 124, 1)
	SetData(tempo_motivos_11, "Local HMI", RW, index + 126, 1)
	SetData(tempo_motivos_12, "Local HMI", RW, index + 128, 1)
	SetData(tempo_motivos_13, "Local HMI", RW, index + 130, 1)
	SetData(tempo_motivos_14, "Local HMI", RW, index + 132, 1)
	SetData(tempo_motivos_15, "Local HMI", RW, index + 134, 1)
	SetData(tempo_motivos_16, "Local HMI", RW, index + 136, 1)	
	SetData(tempo_motivos_17, "Local HMI", RW, index + 138, 1)	
	SetData(tempo_motivos_20, "Local HMI", RW, index + 144, 1)	

	SetData(qtd_paradas_1, "Local HMI", RW, index + 167, 1)
	SetData(qtd_paradas_2, "Local HMI", RW, index + 168, 1)
	SetData(qtd_paradas_3, "Local HMI", RW, index + 169, 1)
	SetData(qtd_paradas_4, "Local HMI", RW, index + 170, 1)
	SetData(qtd_paradas_5, "Local HMI", RW, index + 171, 1)
	SetData(qtd_paradas_6, "Local HMI", RW, index + 172, 1)
	SetData(qtd_paradas_7, "Local HMI", RW, index + 173, 1)
	SetData(qtd_paradas_8, "Local HMI", RW, index + 174, 1)
	SetData(qtd_paradas_9, "Local HMI", RW, index + 175, 1)
	SetData(qtd_paradas_10, "Local HMI", RW, index + 176, 1)
	SetData(qtd_paradas_11, "Local HMI", RW, index + 177, 1)
	SetData(qtd_paradas_12, "Local HMI", RW, index + 178, 1)
	SetData(qtd_paradas_13, "Local HMI", RW, index + 179, 1)
	SetData(qtd_paradas_14, "Local HMI", RW, index + 180, 1)
	SetData(qtd_paradas_15, "Local HMI", RW, index + 181, 1)
	SetData(qtd_paradas_16, "Local HMI", RW, index + 182, 1)
	SetData(qtd_paradas_17, "Local HMI", RW, index + 183, 1)
	SetData(qtd_paradas_20, "Local HMI", RW, index + 186, 1)
	
//cálculo tempo decorrido do turno
	tempo_total = tempo_total_rodando + tempo_aguardando_apontamento + tempo_motivos_1 + tempo_motivos_2 + tempo_motivos_3 + tempo_motivos_4 + tempo_motivos_5 + tempo_motivos_6 + tempo_motivos_7 + tempo_motivos_8 + tempo_motivos_9 + tempo_motivos_10 + tempo_motivos_11 + tempo_motivos_12 + tempo_motivos_13 + tempo_motivos_14 + tempo_motivos_15 + tempo_motivos_16 + tempo_motivos_17 + tempo_motivos_20
	SetData(tempo_total, "Local HMI", RW, index + 100, 1)
	
//cálculo de porcentagem para gráfico
	porcent_aguardando_apontamento = (tempo_aguardando_apontamento * 100) / tempo_total
	porcent_motivos_1 = (tempo_motivos_1 * 100) / tempo_total
	porcent_motivos_2 = (tempo_motivos_2 * 100) / tempo_total
	porcent_motivos_3 = (tempo_motivos_3 * 100) / tempo_total
	porcent_motivos_4 = (tempo_motivos_4 * 100) / tempo_total
	porcent_motivos_5 = (tempo_motivos_5 * 100) / tempo_total
	porcent_motivos_6 = (tempo_motivos_6 * 100) / tempo_total
	porcent_motivos_7 = (tempo_motivos_7 * 100) / tempo_total
	porcent_motivos_8 = (tempo_motivos_8 * 100) / tempo_total
	porcent_motivos_9 = (tempo_motivos_9 * 100) / tempo_total
	porcent_motivos_10 = (tempo_motivos_10 * 100) / tempo_total
	porcent_motivos_11 = (tempo_motivos_11 * 100) / tempo_total
	porcent_motivos_12 = (tempo_motivos_12 * 100) / tempo_total
	porcent_motivos_13 = (tempo_motivos_13 * 100) / tempo_total
	porcent_motivos_14 = (tempo_motivos_14 * 100) / tempo_total
	porcent_motivos_15 = (tempo_motivos_15 * 100) / tempo_total
	porcent_motivos_16 = (tempo_motivos_16  * 100) / tempo_total
	porcent_motivos_17 = (tempo_motivos_17  * 100) / tempo_total	
	porcent_motivos_20 = (tempo_motivos_20  * 100) / tempo_total	
	
	SetData(porcent_aguardando_apontamento, "Local HMI", RW,  index + 146, 1)
	SetData(porcent_motivos_1, "Local HMI", RW,  index + 147, 1)
	SetData(porcent_motivos_2, "Local HMI", RW,  index + 148, 1)
	SetData(porcent_motivos_3, "Local HMI", RW,  index + 149, 1)
	SetData(porcent_motivos_4, "Local HMI", RW,  index + 150, 1)
	SetData(porcent_motivos_5, "Local HMI", RW,  index + 151, 1)
	SetData(porcent_motivos_6, "Local HMI", RW,  index + 152, 1)
	SetData(porcent_motivos_7, "Local HMI", RW,  index + 153, 1)
	SetData(porcent_motivos_8, "Local HMI", RW,  index + 154, 1)
	SetData(porcent_motivos_9, "Local HMI", RW,  index + 155, 1)
	SetData(porcent_motivos_10, "Local HMI", RW,  index + 156, 1)
	SetData(porcent_motivos_11, "Local HMI", RW,  index + 157, 1)
	SetData(porcent_motivos_12, "Local HMI", RW,  index + 158, 1)
	SetData(porcent_motivos_13, "Local HMI", RW,  index + 159, 1)
	SetData(porcent_motivos_14, "Local HMI", RW,  index + 160, 1)
	SetData(porcent_motivos_15, "Local HMI", RW,  index + 161, 1)
	SetData(porcent_motivos_16, "Local HMI", RW,  index + 162, 1)	
	SetData(porcent_motivos_17, "Local HMI", RW,  index + 163, 1)
	SetData(porcent_motivos_20, "Local HMI", RW,  index + 166, 1)	
	
//cálculo de disponibilidade da máquina
	porcent_disponibilidade = (tempo_total_rodando * 100.0) / tempo_total
	SetData(porcent_disponibilidade, "Local HMI", RW, index + 187, 1)

//cálculo de performance
	porcent_performance = (qtd_turno_total / qtd_turno_teorico) * 100.0
	SetData(porcent_performance, "Local HMI", RW, index + 189, 1)

//cálculo de qualidade
	porcent_qualidade = (qtd_turno_pecas_boas / qtd_turno_total) * 100.0
	SetData(porcent_qualidade, "Local HMI", RW, index + 191, 1)
	
//cálculo OEE
	disponibilidade = (tempo_total_rodando * 1.0) / tempo_total
	performance = qtd_turno_total / qtd_turno_teorico
	qualidade = qtd_turno_pecas_boas / qtd_turno_total	
	porcent_oee = (disponibilidade * performance * qualidade) * 100.0
	SetData(porcent_oee, "Local HMI", RW, index + 193, 1)
	
next

end macro_command